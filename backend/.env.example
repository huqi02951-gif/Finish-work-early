# SERVER PORT
PORT=3000

# JWT Auth
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"
ENABLE_DEMO_AUTH="true"
SEED_ADMIN_PASSWORD="replace-with-a-strong-seed-password"

# DATABASE_URL for Prisma connection
# Connection structure: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
# If your password contains '@', encode it as '%40'.
DATABASE_URL="postgresql://db_user:db_password@127.0.0.1:5432/finish_work_early?schema=public"

# ─── Email (nodemailer SMTP) ───
# 配置后邮箱验证码将真实发送邮件；不配置则验证码仅打印到控制台日志
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-password
