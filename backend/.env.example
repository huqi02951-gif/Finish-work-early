# SERVER PORT
PORT=3000

# JWT Auth Secret
JWT_SECRET="FINISH_WORK_PHASE_1_SECRET"
SEED_ADMIN_PASSWORD="Phase2Admin123!"

# DATABASE_URL for Prisma connection
# Connection structure: postgresql://USER:PASSWORD@HOST:PORT/DB_NAME?schema=public
# Since password implicitly has '@', use '%40' to encode.
# Depending on your current runtime, uncomment the correct one:

# Option 1: Local SSH Tunnel (Run when tunneling pgsql2.hostuno.com 5432 to localhost)
DATABASE_URL="postgresql://p3397_finishwork:Ab123123%40@127.0.0.1:5432/p3397_finishwork?schema=public"

# Option 2: Hostuno Direct Network
# DATABASE_URL="postgresql://p3397_finishwork:Ab123123%40@pgsql2.hostuno.com:5432/p3397_finishwork?schema=public"

# ─── Email (nodemailer SMTP) ───
# 配置后邮箱验证码将真实发送邮件；不配置则验证码仅打印到控制台日志
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your-email@qq.com
SMTP_PASS=your-smtp-password
