generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  MANAGER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum PostStatus {
  PUBLISHED
  PENDING
  HIDDEN
  REJECTED
  ARCHIVED
}

enum CommentStatus {
  PUBLISHED
  HIDDEN
}

enum BoardStatus {
  ACTIVE
  HIDDEN
}

enum TagStatus {
  ACTIVE
  HIDDEN
}

enum CatalogStatus {
  DRAFT
  PUBLISHED
  OFFLINE
}

enum PostType {
  DISCUSSION
  TOPIC
  GUIDE
  FAQ
  UPDATE
}

enum PostSourceType {
  USER
  ADMIN
  SEED
}

enum ModerationAction {
  APPROVE
  REJECT
  HIDE
  RESTORE
  DELETE
  PIN
  UNPIN
  LOCK_COMMENTS
  UNLOCK_COMMENTS
}

model User {
  id                 Int          @id @default(autoincrement())
  username           String       @unique
  nickname           String
  passwordHash       String       @map("password_hash")
  email              String?      @unique
  phone              String?      @unique
  avatarUrl          String?      @map("avatar_url")
  bio                String?      @db.Text
  role               UserRole     @default(USER)
  status             UserStatus   @default(ACTIVE)
  clientKey          String?      @unique @map("client_key")
  createdAt          DateTime     @default(now()) @map("created_at")
  updatedAt          DateTime     @updatedAt @map("updated_at")

  posts              Post[]
  comments           Comment[]
  reviewedPosts      Post[]       @relation("PostReviewedBy")
  updatedPageConfigs PageConfig[] @relation("PageConfigUpdatedBy")
  sessions           UserSession[]
  moderationLogs     ModerationLog[] @relation("ModerationLogOperator")

  @@map("users")
}

model Board {
  id             Int         @id @default(autoincrement())
  slug           String      @unique
  name           String
  description    String?     @db.Text
  sortOrder      Int         @default(0) @map("sort_order")
  isOfficial     Boolean     @default(false) @map("is_official")
  requiresReview Boolean     @default(false) @map("requires_review")
  status         BoardStatus @default(ACTIVE)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")
  posts          Post[]

  @@index([status, sortOrder])
  @@map("boards")
}

model Post {
  id                Int            @id @default(autoincrement())
  title             String
  summary           String?        @db.Text
  content           String         @db.Text
  contentData       Json?          @map("content_data")
  category          String         @default("经验分享")
  externalKey       String?        @unique @map("external_key")
  postType          PostType       @default(DISCUSSION) @map("post_type")
  sourceType        PostSourceType @default(USER) @map("source_type")
  isOfficial        Boolean        @default(false) @map("is_official")
  isPinned          Boolean        @default(false) @map("is_pinned")
  pinnedAt          DateTime?      @map("pinned_at")
  status            PostStatus     @default(PUBLISHED)
  commentsLockedAt  DateTime?      @map("comments_locked_at")
  reviewedAt        DateTime?      @map("reviewed_at")
  reviewReason      String?        @db.Text @map("review_reason")
  relatedProductSlug String?       @map("related_product_slug")
  relatedSkillSlug  String?        @map("related_skill_slug")
  relatedPageKey    String?        @map("related_page_key")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")
  deletedAt         DateTime?      @map("deleted_at")

  boardId           Int?           @map("board_id")
  board             Board?         @relation(fields: [boardId], references: [id])
  authorId          Int            @map("author_id")
  author            User           @relation(fields: [authorId], references: [id])
  reviewedById      Int?           @map("reviewed_by_id")
  reviewedBy        User?          @relation("PostReviewedBy", fields: [reviewedById], references: [id])
  comments          Comment[]
  tags              PostTag[]
  moderationLogs    ModerationLog[]

  @@index([authorId])
  @@index([status, createdAt])
  @@index([boardId, status, isPinned, createdAt])
  @@index([isOfficial, status, isPinned, createdAt])
  @@index([postType, status, createdAt])
  @@index([relatedProductSlug])
  @@index([relatedSkillSlug])

  @@map("posts")
}

model Comment {
  id        Int           @id @default(autoincrement())
  content   String        @db.Text
  status    CommentStatus @default(PUBLISHED)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  postId    Int           @map("post_id")
  post      Post          @relation(fields: [postId], references: [id])

  authorId  Int           @map("author_id")
  author    User          @relation(fields: [authorId], references: [id])
  moderationLogs ModerationLog[]

  @@index([postId, status, createdAt])
  @@index([authorId, createdAt])

  @@map("comments")
}

model Tag {
  id        Int       @id @default(autoincrement())
  slug      String    @unique
  name      String    @unique
  sortOrder Int       @default(0) @map("sort_order")
  status    TagStatus @default(ACTIVE)
  createdAt DateTime  @default(now()) @map("created_at")
  postTags  PostTag[]

  @@index([status, sortOrder])
  @@map("tags")
}

model PostTag {
  postId Int  @map("post_id")
  tagId  Int  @map("tag_id")
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId, postId])
  @@map("post_tags")
}

model ModerationLog {
  id         Int              @id @default(autoincrement())
  postId     Int?             @map("post_id")
  commentId  Int?             @map("comment_id")
  operatorId Int              @map("operator_id")
  action     ModerationAction
  reason     String?          @db.Text
  meta       Json?
  createdAt  DateTime         @default(now()) @map("created_at")
  post       Post?            @relation(fields: [postId], references: [id], onDelete: SetNull)
  comment    Comment?         @relation(fields: [commentId], references: [id], onDelete: SetNull)
  operator   User             @relation("ModerationLogOperator", fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([commentId, createdAt])
  @@index([operatorId, createdAt])
  @@map("moderation_logs")
}

model PageConfig {
  id            Int       @id @default(autoincrement())
  pageKey       String    @unique @map("page_key")
  configData    Json      @map("config_data")
  version       Int       @default(1)
  schemaVersion Int       @default(1) @map("schema_version")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  publishedAt   DateTime? @map("published_at")
  deletedAt     DateTime? @map("deleted_at")
  updatedById   Int?      @map("updated_by_id")
  updatedBy     User?     @relation("PageConfigUpdatedBy", fields: [updatedById], references: [id])

  @@index([deletedAt])
  @@map("page_configs")
}

model Product {
  id         Int               @id @default(autoincrement())
  slug       String            @unique
  name       String            @db.VarChar(100)
  category   String            @db.VarChar(100)
  summary    String            @db.Text
  coverUrl   String?           @map("cover_url")
  targetUrl  String?           @map("target_url")
  status     CatalogStatus     @default(DRAFT)
  sortOrder  Int               @default(0) @map("sort_order")
  detailData Json              @map("detail_data")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  deletedAt  DateTime?         @map("deleted_at")
  skills     ProductSkillRel[]

  @@index([status, sortOrder])
  @@index([deletedAt])
  @@map("products")
}

model Skill {
  id         Int               @id @default(autoincrement())
  slug       String            @unique
  title      String            @db.VarChar(100)
  category   String            @db.VarChar(100)
  summary    String            @db.Text
  toolRoute  String?           @map("tool_route")
  formLabel  String?           @map("form_label")
  status     CatalogStatus     @default(DRAFT)
  sortOrder  Int               @default(0) @map("sort_order")
  detailData Json              @map("detail_data")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  deletedAt  DateTime?         @map("deleted_at")
  products   ProductSkillRel[]

  @@index([status, sortOrder])
  @@index([deletedAt])
  @@map("skills")
}

model ProductSkillRel {
  productId Int     @map("product_id")
  skillId   Int     @map("skill_id")
  sortOrder Int     @default(0) @map("sort_order")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([productId, skillId])
  @@index([productId, sortOrder])
  @@index([skillId, sortOrder])
  @@map("product_skill_rel")
}

model VerificationCode {
  id        Int       @id @default(autoincrement())
  type      String    // 'email' | 'phone'
  target    String    // 邮箱地址或手机号
  code      String    @db.VarChar(6)  // 6 位验证码
  purpose   String    @default("login")  // 'login' | 'register'
  used      Boolean   @default(false)
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")

  @@index([type, target, purpose, used, expiresAt])
  @@map("verification_codes")
}

model UserSession {
  id         Int       @id @default(autoincrement())
  userId     Int       @map("user_id")
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceInfo String?   @map("device_info")
  ipAddress  String?   @map("ip_address")
  tokenHash  String?   @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId, expiresAt])
  @@map("user_sessions")
}
