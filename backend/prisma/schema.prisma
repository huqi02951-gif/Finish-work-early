generator client {
  provider   = "prisma-client-js"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  USER
  ADMIN
  MANAGER
}

enum UserStatus {
  ACTIVE
  DISABLED
}

enum PostStatus {
  PUBLISHED
  PENDING
  HIDDEN
  REJECTED
  ARCHIVED
}

enum CommentStatus {
  PUBLISHED
  HIDDEN
}

enum BoardStatus {
  ACTIVE
  HIDDEN
}

enum TagStatus {
  ACTIVE
  HIDDEN
}

enum CatalogStatus {
  DRAFT
  PUBLISHED
  OFFLINE
}

enum PostType {
  DISCUSSION
  TOPIC
  GUIDE
  FAQ
  UPDATE
}

enum PostSourceType {
  USER
  ADMIN
  SEED
}

enum ModerationAction {
  APPROVE
  REJECT
  HIDE
  RESTORE
  DELETE
  PIN
  UNPIN
  LOCK_COMMENTS
  UNLOCK_COMMENTS
}

enum PantryIdentityStatus {
  ACTIVE
  MUTED
  BANNED
}

enum PantryVisibilityMode {
  PERMANENT
  EPHEMERAL
}

enum PantryReactionType {
  FIRE
  BRICK
  EYES
  TEA
  SUPPORT
}

enum PantryReportTargetType {
  POST
  COMMENT
  LISTING
  MESSAGE
}

enum PantryReportStatus {
  OPEN
  REVIEWING
  RESOLVED
  REJECTED
}

enum MarketListingType {
  SELL
  WANTED
}

enum MarketListingStatus {
  ACTIVE
  RESERVED
  SOLD
  CANCELLED
  HIDDEN
  EXPIRED
}

enum TradeOrderStatus {
  REQUESTED
  ACCEPTED
  PAID_OFF_PLATFORM
  COMPLETED
  CANCELLED
  DISPUTED
}

enum DirectMessageStatus {
  SENT
  HIDDEN
}

enum PantryNotificationType {
  ORDER
  MESSAGE
  REPORT
  SYSTEM
}

model User {
  id           Int        @id @default(autoincrement())
  username     String     @unique
  nickname     String
  passwordHash String     @map("password_hash")
  email        String?    @unique
  phone        String?    @unique
  avatarUrl    String?    @map("avatar_url")
  bio          String?    @db.Text
  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)
  clientKey    String?    @unique @map("client_key")
  createdAt    DateTime   @default(now()) @map("created_at")
  updatedAt    DateTime   @updatedAt @map("updated_at")

  posts              Post[]
  comments           Comment[]
  reviewedPosts      Post[]            @relation("PostReviewedBy")
  updatedPageConfigs PageConfig[]      @relation("PageConfigUpdatedBy")
  sessions           UserSession[]
  moderationLogs     ModerationLog[]   @relation("ModerationLogOperator")
  customerContexts   CustomerContext[]
  drafts             Draft[]
  artifacts          Artifact[]
  auditLogs          AuditLog[]        @relation("AuditLogOperator")
  communityIdentity  CommunityIdentity?
  pantryReactions    PostReaction[]
  pantryReports      Report[]          @relation("ReportReporter")
  marketListings     MarketListing[]   @relation("MarketListingSeller")
  buyingOrders       TradeOrder[]      @relation("TradeOrderBuyer")
  sellingOrders      TradeOrder[]      @relation("TradeOrderSeller")
  conversationsA     Conversation[]    @relation("ConversationUserA")
  conversationsB     Conversation[]    @relation("ConversationUserB")
  directMessages     DirectMessage[]   @relation("DirectMessageSender")
  pantryBookmarks    PostBookmark[]
  pantryNotifications PantryNotification[]

  @@map("users")
}

model Board {
  id             Int         @id @default(autoincrement())
  slug           String      @unique
  name           String
  description    String?     @db.Text
  sortOrder      Int         @default(0) @map("sort_order")
  isOfficial     Boolean     @default(false) @map("is_official")
  requiresReview Boolean     @default(false) @map("requires_review")
  status         BoardStatus @default(ACTIVE)
  createdAt      DateTime    @default(now()) @map("created_at")
  updatedAt      DateTime    @updatedAt @map("updated_at")
  deletedAt      DateTime?   @map("deleted_at")
  posts          Post[]

  @@index([status, sortOrder])
  @@map("boards")
}

model Post {
  id                 Int            @id @default(autoincrement())
  title              String
  summary            String?        @db.Text
  content            String         @db.Text
  contentData        Json?          @map("content_data")
  category           String         @default("经验分享")
  externalKey        String?        @unique @map("external_key")
  postType           PostType       @default(DISCUSSION) @map("post_type")
  sourceType         PostSourceType @default(USER) @map("source_type")
  isOfficial         Boolean        @default(false) @map("is_official")
  isPinned           Boolean        @default(false) @map("is_pinned")
  pinnedAt           DateTime?      @map("pinned_at")
  status             PostStatus     @default(PUBLISHED)
  commentsLockedAt   DateTime?      @map("comments_locked_at")
  visibilityMode     PantryVisibilityMode @default(PERMANENT) @map("visibility_mode")
  expiresAt          DateTime?      @map("expires_at")
  anonymousAlias     String?        @map("anonymous_alias") @db.VarChar(80)
  heatScore          Int            @default(0) @map("heat_score")
  reactionCount      Int            @default(0) @map("reaction_count")
  bookmarkCount      Int            @default(0) @map("bookmark_count")
  reviewedAt         DateTime?      @map("reviewed_at")
  reviewReason       String?        @map("review_reason") @db.Text
  relatedProductSlug String?        @map("related_product_slug")
  relatedSkillSlug   String?        @map("related_skill_slug")
  relatedPageKey     String?        @map("related_page_key")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")
  deletedAt          DateTime?      @map("deleted_at")

  boardId        Int?            @map("board_id")
  board          Board?          @relation(fields: [boardId], references: [id])
  authorId       Int             @map("author_id")
  author         User            @relation(fields: [authorId], references: [id])
  reviewedById   Int?            @map("reviewed_by_id")
  reviewedBy     User?           @relation("PostReviewedBy", fields: [reviewedById], references: [id])
  comments       Comment[]
  tags           PostTag[]
  moderationLogs ModerationLog[]
  reactions      PostReaction[]
  bookmarks      PostBookmark[]

  @@index([authorId])
  @@index([status, createdAt])
  @@index([boardId, status, isPinned, createdAt])
  @@index([isOfficial, status, isPinned, createdAt])
  @@index([postType, status, createdAt])
  @@index([boardId, status, visibilityMode, expiresAt])
  @@index([heatScore, reactionCount, createdAt])
  @@index([relatedProductSlug])
  @@index([relatedSkillSlug])
  @@map("posts")
}

model Comment {
  id        Int           @id @default(autoincrement())
  content   String        @db.Text
  status    CommentStatus @default(PUBLISHED)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  deletedAt DateTime?     @map("deleted_at")

  postId Int  @map("post_id")
  post   Post @relation(fields: [postId], references: [id])

  authorId       Int             @map("author_id")
  author         User            @relation(fields: [authorId], references: [id])
  moderationLogs ModerationLog[]

  @@index([postId, status, createdAt])
  @@index([authorId, createdAt])
  @@map("comments")
}

model CommunityIdentity {
  id          Int                  @id @default(autoincrement())
  userId      Int                  @unique @map("user_id")
  alias       String               @unique @db.VarChar(80)
  color       String               @db.VarChar(24)
  status      PantryIdentityStatus @default(ACTIVE)
  mutedUntil  DateTime?            @map("muted_until")
  coffeeQrUrl String?              @map("coffee_qr_url") @db.Text
  coffeeNote  String?              @map("coffee_note") @db.Text
  coffeePublic Boolean             @default(false) @map("coffee_public")
  reputation  Int                  @default(0)
  createdAt   DateTime             @default(now()) @map("created_at")
  updatedAt   DateTime             @updatedAt @map("updated_at")
  user        User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, updatedAt])
  @@map("community_identities")
}

model PostBookmark {
  id        Int      @id @default(autoincrement())
  postId    Int      @map("post_id")
  userId    Int      @map("user_id")
  createdAt DateTime @default(now()) @map("created_at")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([userId, createdAt])
  @@index([postId, createdAt])
  @@map("post_bookmarks")
}

model PostReaction {
  id        Int                 @id @default(autoincrement())
  postId    Int                 @map("post_id")
  userId    Int                 @map("user_id")
  type      PantryReactionType
  createdAt DateTime            @default(now()) @map("created_at")
  post      Post                @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, type])
  @@index([userId, createdAt])
  @@index([postId, type])
  @@map("post_reactions")
}

model Report {
  id          Int                    @id @default(autoincrement())
  reporterId  Int                    @map("reporter_id")
  targetType  PantryReportTargetType @map("target_type")
  targetId    Int                    @map("target_id")
  reason      String                 @db.VarChar(100)
  detail      String?                @db.Text
  status      PantryReportStatus     @default(OPEN)
  createdAt   DateTime               @default(now()) @map("created_at")
  resolvedAt  DateTime?              @map("resolved_at")
  reporter    User                   @relation("ReportReporter", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([targetType, targetId, status])
  @@index([reporterId, createdAt])
  @@index([status, createdAt])
  @@map("reports")
}

model MarketListing {
  id              Int                 @id @default(autoincrement())
  sellerId        Int                 @map("seller_id")
  type            MarketListingType   @default(SELL)
  title           String              @db.VarChar(160)
  description     String              @db.Text
  category        String              @db.VarChar(80)
  condition       String?             @db.VarChar(80)
  priceCents      Int?                @map("price_cents")
  priceText       String?             @map("price_text") @db.VarChar(80)
  status          MarketListingStatus @default(ACTIVE)
  anonymousAlias  String              @map("anonymous_alias") @db.VarChar(80)
  expiresAt       DateTime?           @map("expires_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  seller          User                @relation("MarketListingSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  orders          TradeOrder[]

  @@index([status, type, createdAt])
  @@index([sellerId, status, createdAt])
  @@index([category, status, createdAt])
  @@map("market_listings")
}

model TradeOrder {
  id              Int              @id @default(autoincrement())
  listingId       Int              @map("listing_id")
  buyerId         Int              @map("buyer_id")
  sellerId        Int              @map("seller_id")
  status          TradeOrderStatus @default(REQUESTED)
  note            String?          @db.Text
  offPlatformNote String?          @map("off_platform_note") @db.Text
  disputeReason   String?          @map("dispute_reason") @db.Text
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  listing         MarketListing    @relation(fields: [listingId], references: [id], onDelete: Cascade)
  buyer           User             @relation("TradeOrderBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller          User             @relation("TradeOrderSeller", fields: [sellerId], references: [id], onDelete: Cascade)

  @@index([buyerId, status, createdAt])
  @@index([sellerId, status, createdAt])
  @@index([listingId, createdAt])
  @@map("trade_orders")
}

model Conversation {
  id          Int             @id @default(autoincrement())
  userAId     Int             @map("user_a_id")
  userBId     Int             @map("user_b_id")
  listingId   Int?            @map("listing_id")
  orderId     Int?            @map("order_id")
  lastMessage String?         @map("last_message") @db.Text
  lastAt      DateTime        @default(now()) @map("last_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  userA       User            @relation("ConversationUserA", fields: [userAId], references: [id], onDelete: Cascade)
  userB       User            @relation("ConversationUserB", fields: [userBId], references: [id], onDelete: Cascade)
  messages    DirectMessage[]

  @@unique([userAId, userBId, listingId, orderId])
  @@index([userAId, lastAt])
  @@index([userBId, lastAt])
  @@map("conversations")
}

model DirectMessage {
  id             Int                 @id @default(autoincrement())
  conversationId Int                 @map("conversation_id")
  senderId       Int                 @map("sender_id")
  content        String              @db.Text
  status         DirectMessageStatus @default(SENT)
  readAt         DateTime?           @map("read_at")
  createdAt      DateTime            @default(now()) @map("created_at")
  conversation   Conversation        @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User                @relation("DirectMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@map("direct_messages")
}

model PantryNotification {
  id          Int                     @id @default(autoincrement())
  userId      Int                     @map("user_id")
  type        PantryNotificationType
  title       String                  @db.VarChar(160)
  body        String?                 @db.Text
  targetType  String?                 @map("target_type") @db.VarChar(80)
  targetId    Int?                    @map("target_id")
  readAt      DateTime?               @map("read_at")
  createdAt   DateTime                @default(now()) @map("created_at")
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([type, createdAt])
  @@map("pantry_notifications")
}

model Tag {
  id        Int       @id @default(autoincrement())
  slug      String    @unique
  name      String    @unique
  sortOrder Int       @default(0) @map("sort_order")
  status    TagStatus @default(ACTIVE)
  createdAt DateTime  @default(now()) @map("created_at")
  postTags  PostTag[]

  @@index([status, sortOrder])
  @@map("tags")
}

model PostTag {
  postId Int  @map("post_id")
  tagId  Int  @map("tag_id")
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId, postId])
  @@map("post_tags")
}

model ModerationLog {
  id         Int              @id @default(autoincrement())
  postId     Int?             @map("post_id")
  commentId  Int?             @map("comment_id")
  operatorId Int              @map("operator_id")
  action     ModerationAction
  reason     String?          @db.Text
  meta       Json?
  createdAt  DateTime         @default(now()) @map("created_at")
  post       Post?            @relation(fields: [postId], references: [id], onDelete: SetNull)
  comment    Comment?         @relation(fields: [commentId], references: [id], onDelete: SetNull)
  operator   User             @relation("ModerationLogOperator", fields: [operatorId], references: [id], onDelete: Cascade)

  @@index([postId, createdAt])
  @@index([commentId, createdAt])
  @@index([operatorId, createdAt])
  @@map("moderation_logs")
}

model PageConfig {
  id            Int       @id @default(autoincrement())
  pageKey       String    @unique @map("page_key")
  configData    Json      @map("config_data")
  version       Int       @default(1)
  schemaVersion Int       @default(1) @map("schema_version")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  publishedAt   DateTime? @map("published_at")
  deletedAt     DateTime? @map("deleted_at")
  updatedById   Int?      @map("updated_by_id")
  updatedBy     User?     @relation("PageConfigUpdatedBy", fields: [updatedById], references: [id])

  @@index([deletedAt])
  @@map("page_configs")
}

model Product {
  id         Int               @id @default(autoincrement())
  slug       String            @unique
  name       String            @db.VarChar(100)
  category   String            @db.VarChar(100)
  summary    String            @db.Text
  coverUrl   String?           @map("cover_url")
  targetUrl  String?           @map("target_url")
  status     CatalogStatus     @default(DRAFT)
  sortOrder  Int               @default(0) @map("sort_order")
  detailData Json              @map("detail_data")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  deletedAt  DateTime?         @map("deleted_at")
  skills     ProductSkillRel[]

  @@index([status, sortOrder])
  @@index([deletedAt])
  @@map("products")
}

model Skill {
  id         Int               @id @default(autoincrement())
  slug       String            @unique
  title      String            @db.VarChar(100)
  category   String            @db.VarChar(100)
  summary    String            @db.Text
  toolRoute  String?           @map("tool_route")
  formLabel  String?           @map("form_label")
  status     CatalogStatus     @default(DRAFT)
  sortOrder  Int               @default(0) @map("sort_order")
  detailData Json              @map("detail_data")
  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")
  deletedAt  DateTime?         @map("deleted_at")
  products   ProductSkillRel[]

  @@index([status, sortOrder])
  @@index([deletedAt])
  @@map("skills")
}

model ProductSkillRel {
  productId Int     @map("product_id")
  skillId   Int     @map("skill_id")
  sortOrder Int     @default(0) @map("sort_order")
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  skill     Skill   @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([productId, skillId])
  @@index([productId, sortOrder])
  @@index([skillId, sortOrder])
  @@map("product_skill_rel")
}

model VerificationCode {
  id        Int      @id @default(autoincrement())
  type      String // 'email' | 'phone'
  target    String // 邮箱地址或手机号
  code      String   @db.VarChar(6) // 6 位验证码
  purpose   String   @default("login") // 'login' | 'register'
  used      Boolean  @default(false)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([type, target, purpose, used, expiresAt])
  @@map("verification_codes")
}

model UserSession {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  tokenHash  String?  @unique @map("token_hash")
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([userId, expiresAt])
  @@map("user_sessions")
}

model CustomerContext {
  id            Int       @id @default(autoincrement())
  userId        Int       @map("user_id")
  customerName  String    @map("customer_name") @db.VarChar(150)
  contactPerson String?   @map("contact_person") @db.VarChar(100)
  phone         String?   @db.VarChar(50)
  industry      String?   @db.VarChar(100)
  channel       String?   @db.VarChar(100)
  remark        String?   @db.Text
  extraData     Json?     @map("extra_data")
  lastUsedAt    DateTime? @map("last_used_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, deletedAt, updatedAt])
  @@index([customerName])
  @@map("customer_contexts")
}

model Draft {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  toolId    String    @map("tool_id") @db.VarChar(100)
  title     String    @db.VarChar(200)
  data      Json
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, toolId, updatedAt])
  @@index([userId, deletedAt, updatedAt])
  @@map("drafts")
}

model Artifact {
  id        Int       @id @default(autoincrement())
  userId    Int       @map("user_id")
  toolId    String    @map("tool_id") @db.VarChar(100)
  title     String    @db.VarChar(200)
  content   String    @db.Text
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  deletedAt DateTime? @map("deleted_at")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, toolId, createdAt])
  @@index([userId, deletedAt, createdAt])
  @@map("artifacts")
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  module     String   @db.VarChar(100)
  action     String   @db.VarChar(100)
  targetType String?  @map("target_type") @db.VarChar(100)
  targetId   String?  @map("target_id") @db.VarChar(100)
  operatorId Int?     @map("operator_id")
  detail     Json?
  createdAt  DateTime @default(now()) @map("created_at")
  operator   User?    @relation("AuditLogOperator", fields: [operatorId], references: [id], onDelete: SetNull)

  @@index([module, createdAt])
  @@index([operatorId, createdAt])
  @@index([targetType, targetId, createdAt])
  @@map("audit_logs")
}
